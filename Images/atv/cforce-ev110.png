/* <![CDATA[ */
function setActiveIndexByID(id, index) {
    const canvas = document.getElementById(id).querySelector('canvas');
    const context = canvas.getContext("2d");
	  const viewers = window.CI360._viewers;
    for(let i = 0; i<viewers.length; i++){
			if(viewers[i].id === id){ 
				const image = viewers[i].imagesX[index];
				if (image != undefined) {
						context.drawImage(image, 0, 0, canvas.width, canvas.height);
						viewers[i].activeImageX = index+1;
				}
			}
		}
}


jQuery(function($) {
	$('.container360-multicolor .color-switcher .color-switcher-item, .cloudimage-360-down:not(.not-active), .cloudimage-360-up:not(.not-active)').on('click', function(e){
		e.preventDefault();
		var $button = $(this);																				 
		var key = $button.data('key');
		
		var currentlyActive = $button.parents('.container360-multicolor').find('.container360.active');
		if(currentlyActive.length){
			var activeSlide =	window.CI360.getActiveIndexByID(currentlyActive.attr('id'), 'x-axis' );
			if( activeSlide ){
				activeSlide = parseInt(activeSlide);
				setActiveIndexByID(key, activeSlide);
			}
		}
		
		
		$button.addClass('active').siblings().removeClass('active');
		$button.parents('.container360-multicolor').find('#' + key).addClass('active').siblings().removeClass('active');
	});
	
	$('.cloudimage-360.cloudimage-360 .cloudimage-360-buttons').on('click', function(e){
		e.preventDefault();
		e.stopPropagation();
	});
});



